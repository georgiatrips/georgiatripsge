rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && (
          request.auth.token.email == 'georgiatrips5@gmail.com'
          || (
            exists(/databases/$(database)/documents/users/$(request.auth.token.email))
            && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.isAdmin == true
          )
        );
    }

    // საჯარო ინფორმაცია
    match /tours/{tourId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /cars/{carId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /featuredTours/{featuredId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Leads / Inbox collections
    // Public forms can create documents (no auth required).
    // Only admins can read/manage all incoming leads.
    match /tourBookings/{bookingId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'tourName']);
      allow read, update, delete: if isAdmin();
    }
    match /carBookings/{bookingId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'carName']);
      allow read, update, delete: if isAdmin();
    }
    match /subscribers/{subscriberId} {
      allow create: if request.resource.data.keys().hasAll(['email']);
      allow read, update, delete: if isAdmin();
    }
    match /contactMessages/{messageId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'message']);
      allow read, update, delete: if isAdmin();
    }

    // შენახული ტურების ლოგიკა
    match /users/{userId}/savedTours/{tourId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // მომხმარებლის პროფილი
    match /reviews/{reviewId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /users/{email} {
      allow read: if request.auth != null && request.auth.token.email == email;
      allow write: if isAdmin();
    }

    // Visitor Analytics & Traffic Logs
    match /traffic_logs/{logId} {
      allow create, update: if true;
      allow read, delete: if isAdmin();
    }
  }
}
