rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // საჯარო ინფორმაცია
    match /tours/{tourId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /cars/{carId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /featuredTours/{featuredId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // შენახული ტურების ლოგიკა
    match /users/{userId}/savedTours/{tourId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // მომხმარებლის პროფილი
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}